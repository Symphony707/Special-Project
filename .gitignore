# Ignore environment files
.env
.env.*

# Ignore dependencies
node_modules/
venv/
__pycache__/
*.py[cod]

# Ignore system files
.DS_Store
Thumbs.db

# Ignore IDE/editor files
.vscode/
.idea/

# Ignore logs
*.log

# Ignore build outputs
dist/
build/
.next/

# Ignore OS-specific or temp files
*.swp
*.bak
*~
tmp/

# Project-specific ignores
*.db
*.csv
*.xlsx
*.xls
*.parquet
datamind/data/

# ── Environment & Secrets ──
.env.local
.env.*.local
*.secret
secrets.toml

# ── Database files ──
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── User uploaded data ──
data/
uploads/
**/uploads/

# ── Generated artifacts ──
artifacts/
scratch/

# ── Python cache (extras) ──
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# ── Data files that may contain real data (extras) ──
!.env.example
!requirements.txt
!README.md

# ── OS files (extras) ──
.DS_Store?
._*
ehthumbs.db

# ── IDE (extras) ──
.vscode/settings.json
*.swo

# ── Streamlit ──
.streamlit/secrets.toml

# ── Build (extras) ──
*.egg-info/
